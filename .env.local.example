# Supabase
# Get these from your Supabase Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Stripe
# Get these from your Stripe Dashboard (Test Mode first, then Live Mode)
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
# Use `stripe listen` for local, or create a Webhook Endpoint in Stripe Dashboard for production
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Product Price IDs
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_...
NEXT_PUBLIC_STRIPE_BUSINESS_PRICE_ID=price_...

# App URL
# Local: http://localhost:3000
# Production: https://launchfast.vercel.app
NEXT_PUBLIC_URL=http://localhost:3000

# Database
DB_PASSWORD=your-db-password